---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ThemeToggle } from "@/components/theme-toggle";
import { withBase } from "@/lib/utils";

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="relative isolate">
    <header
      class="bg-background/70 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-30 flex h-14 items-center justify-between border-b border-border px-4 backdrop-blur md:px-8"
    >
      <a
        href={withBase("/")}
        class="text-foreground font-semibold tracking-tight"
        aria-label="Cosmos Repository home"
      >
        <span class="inline-flex items-center gap-2">
          <span
            aria-hidden="true"
            class="bg-primary inline-block size-2.5 rounded-full"
          ></span>
          Cosmos Repository
        </span>
      </a>
      <nav
        class="text-muted-foreground hidden items-center gap-6 text-sm font-medium md:flex"
        aria-label="Primary"
      >
        <a class="hover:text-foreground" href={withBase("/docs/getting-started")}
          >Docs</a
        >
        <a
          class="hover:text-foreground"
          href={withBase("/docs/release-notes")}>Release notes</a
        >
        <a
          class="hover:text-foreground"
          href="https://www.nuget.org/packages/IEvangelist.Azure.CosmosRepository"
          target="_blank"
          rel="noreferrer">NuGet</a
        >
      </nav>
      <div class="flex items-center gap-1">
        <ThemeToggle client:load />
        <a
          href="https://github.com/IEvangelist/azure-cosmos-dotnet-repository"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub repository"
          class="hover:bg-muted hover:text-foreground inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
        >
          <svg
            role="img"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 fill-current"
            aria-hidden="true"
          >
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55v-1.93c-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.39.97.1-.75.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18.93-.26 1.93-.39 2.92-.39s1.99.13 2.92.39c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.79 1.07.79 2.15v3.19c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
            ></path>
          </svg>
        </a>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer
      class="border-t border-border px-4 py-8 text-sm text-muted-foreground md:px-8"
    >
      <div
        class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 md:flex-row md:items-center"
      >
        <p>
          © {new Date().getFullYear()} David Pine and contributors. MIT
          licensed.
        </p>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
          <a
            class="hover:text-foreground"
            href="https://github.com/IEvangelist/azure-cosmos-dotnet-repository"
            >Source</a
          >
          <a
            class="hover:text-foreground"
            href="https://www.nuget.org/packages/IEvangelist.Azure.CosmosRepository"
            >NuGet</a
          >
          <a
            class="hover:text-foreground"
            href="https://discord.com/invite/qMXrX4shAv">Discord</a
          >
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
