---
import "@/styles/global.css";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = "The Azure Cosmos DB Repository .NET SDK — modern docs.",
  ogImage,
  noIndex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle =
  title === "Cosmos Repository"
    ? "Cosmos Repository — Azure Cosmos DB .NET SDK"
    : `${title} · Cosmos Repository`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo.svg`}
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo.png`}
    />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#3a3aff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a16" media="(prefers-color-scheme: dark)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta
      property="og:image"
      content={ogImage ?? new URL(`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo-large.png`, Astro.site).toString()}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={ogImage ?? new URL(`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo-large.png`, Astro.site).toString()}
    />

    {/* Theme bootstrap: avoid FOUC by setting the .dark class before paint. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("cosmos-repo-theme");
          var prefersDark =
            window.matchMedia &&
            window.matchMedia("(prefers-color-scheme: dark)").matches;
          var dark = stored ? stored === "dark" : prefersDark;
          document.documentElement.classList.toggle("dark", dark);
          document.documentElement.style.colorScheme = dark ? "dark" : "light";
        } catch (_) {
          /* ignore */
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <slot />
  </body>
</html>
