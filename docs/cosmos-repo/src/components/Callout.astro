---
import { Info, Lightbulb, AlertTriangle, OctagonAlert, CheckCircle2 } from "lucide-react";

export interface Props {
  type?: "info" | "tip" | "warning" | "danger" | "success";
  title?: string;
}

const { type = "info", title } = Astro.props;

const styles: Record<string, string> = {
  info: "callout-info",
  tip: "callout-tip",
  warning: "callout-warning",
  danger: "callout-danger",
  success: "callout-success",
};

const labels: Record<string, string> = {
  info: title ?? "Note",
  tip: title ?? "Tip",
  warning: title ?? "Warning",
  danger: title ?? "Danger",
  success: title ?? "Success",
};

const icons: Record<string, typeof Info> = {
  info: Info,
  tip: Lightbulb,
  warning: AlertTriangle,
  danger: OctagonAlert,
  success: CheckCircle2,
};

const Icon = icons[type];
---

<aside
  role="note"
  aria-label={labels[type]}
  class:list={[
    "callout not-prose my-5 flex gap-3 rounded-lg border border-l-4 p-4 text-sm shadow-sm",
    styles[type],
  ]}
>
  <span
    class="callout-icon mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-md"
    aria-hidden="true"
  >
    <Icon className="size-4" aria-hidden="true" />
  </span>
  <div class="min-w-0 flex-1 text-foreground">
    <p class="callout-title mb-1 font-semibold">{labels[type]}</p>
    <div class="callout-body text-foreground/90 leading-6 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0">
      <slot />
    </div>
  </div>
</aside>
